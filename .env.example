# ── Port mapping ────────────────────────────────────────────
TARGET_PORT=8001          # Vulnerable app (host-side)
LOG_COLLECTOR_PORT=8002   # Log collector (host-side)

SOC_API_PORT=8000         # SOC backend API
SOC_UI_PORT=5173          # SOC dashboard
DETECTOR_PORT=8003        # Detection engine
EXPLAINER_PORT=8004       # AI explainer

# ── Docker Compose profile ─────────────────────────────────
# Compose profile:
#   '' (empty)   → only core services run
#   'dashboard'  → include SOC dashboard services
COMPOSE_PROFILE=

# ── Application config ─────────────────────────────────────
LOG_COLLECTOR_URL=http://log-collector:8000/log
